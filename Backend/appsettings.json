{
  "MongoDB": {
    "ConnectionString": "mongodb://localhost:27017",
    "ContainerConnectionString": "mongodb://database:27017",
    "CombineDatabase": "CombineDatabase"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  },
  "LexboxAuth": {
    "Authority": "https://lexbox.org",
    "AuthorizationEndpoint": "https://lexbox.org/api/oauth/open-id-auth",
    "ClientId": "the-combine",
    "OpenIdConfigUrl": "https://lexbox.org/.well-known/openid-configuration",
    "Prompt": "select_account",
    "Scope": "profile openid offline_access sendandreceive"
  },
  "AllowedHosts": "*"
}
