{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "command": "dotnet",
      "type": "process",
      "args": ["build", "${workspaceFolder}/Backend/BackendFramework.csproj"],
      "problemMatcher": "$tsc"
    },
    {
      "label": "publish",
      "command": "dotnet",
      "type": "process",
      "args": ["publish", "${workspaceFolder}/Backend/BackendFramework.csproj"],
      "problemMatcher": "$tsc"
    },
    {
      "label": "run-server",
      "command": "dotnet",
      "type": "process",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/Backend/BackendFramework.csproj"
      ],
      "problemMatcher": "$tsc"
    },
    {
      "label": "run-mongo",
      "command": "npm",
      "type": "process",
      "args": ["run", "database"],
      "problemMatcher": "$tsc"
    }
  ]
}
